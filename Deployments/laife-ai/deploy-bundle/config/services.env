PADDLE_REC_DIR=/opt/laife/models/paddle-ocr-model/rec/ch/ch_PP-OCRv4_rec_infer/
PADDLE_CLS_DIR=/opt/laife/models/paddle-ocr-model/cls/ch_ppocr_mobile_v2.0_cls_infer/

# === realtime_rag 数据路径 ===
