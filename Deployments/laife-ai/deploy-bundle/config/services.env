ENTITY_MODEL_NAME=/opt/laife/models/Qwen3.5-4B
LAIFE_INTENT_ROUTER_MODEL=/opt/laife/models/Qwen3.5-4B
ASR_MODEL_PATH=/opt/laife/models/Qwen3-ASR-0.6B
